{
  "name": "HUD Default",
  "version": "1.0.0",

  "palette": {
    "background": "#000000",
    "reticleAccent": "#ffffff",
    "cardSurface": "rgba(255,255,255,0.06)",
    "cardBorder": "rgba(255,255,255,0.12)",
    "cardText": "#e0e0e0",
    "focusHighlight": "#ffffff"
  },

  "node": {
    "types": {
      "page":       { "color": "#ffffff", "radius": 2.8, "ringWidth": 0.12, "emissive": 0.6 },
      "meta":       { "color": "#6ec6ff", "radius": 1.4, "ringWidth": 0.08, "emissive": 0.3 },
      "tag":        { "color": "#81c784", "radius": 1.2, "ringWidth": 0.07, "emissive": 0.3 },
      "breadcrumb": { "color": "#ffb74d", "radius": 1.0, "ringWidth": 0.06, "emissive": 0.25 },
      "heading":    { "color": "#ba68c8", "radius": 1.3, "ringWidth": 0.07, "emissive": 0.3 },
      "media":      { "color": "#4dd0e1", "radius": 1.1, "ringWidth": 0.06, "emissive": 0.25 },
      "link-group": { "color": "#90a4ae", "radius": 1.0, "ringWidth": 0.05, "emissive": 0.2 }
    },
    "idleOpacity": 0.35,
    "focusOpacity": 0.9,
    "recessionOpacity": 0.08,
    "breathingAmplitude": 0.03,
    "breathingFrequency": 0.8
  },

  "connector": {
    "types": {
      "metadata":  { "color": "#6ec6ff" },
      "tagged":    { "color": "#81c784" },
      "crumb":     { "color": "#ffb74d" },
      "contains":  { "color": "#ba68c8" },
      "child-of":  { "color": "#ce93d8" },
      "links-to":  { "color": "#90a4ae" }
    },
    "idleOpacity": 0.06,
    "hoverOpacity": 0.55,
    "bloomIntensity": 1.2
  },

  "label": {
    "fontSize": 0.35,
    "maxChars": 45,
    "gazeDelayMs": 230,
    "fadeInMs": 200,
    "fadeOutMs": 150,
    "idleOpacity": 0,
    "focusOpacity": 0.9,
    "color": "#ffffff",
    "outlineWidth": 0.015,
    "outlineColor": "#000000"
  },

  "reticle": {
    "innerRadius": 0.012,
    "outerRadius": 0.018,
    "segments": 48,
    "color": "#ffffff",
    "idleOpacity": 0.25,
    "targetingOpacity": 0.8,
    "pulseFrequency": 1.5,
    "targetingBlinkRate": 3.0
  },

  "bloom": {
    "strength": 0.6,
    "radius": 0.4,
    "threshold": 0.85
  },

  "vignette": {
    "intensity": 0.45,
    "smoothness": 0.9
  },

  "camera": {
    "fov": 60,
    "near": 0.1,
    "far": 2000,
    "initialPosition": [0, 40, 120],
    "fogColor": "#000000",
    "fogDensity": 0.004,
    "orbitDamping": 0.08,
    "transitionDurationMs": 800
  },

  "entryAnimation": {
    "ringDelayMs": 300,
    "fadeDurationMs": 800
  },

  "infoCard": {
    "width": "320px",
    "blur": "20px",
    "borderRadius": "16px",
    "padding": "20px",
    "maxHeight": "400px"
  },

  "agent": {
    "micSize": "44px",
    "micIdleColor": "rgba(255,255,255,0.3)",
    "micActiveColor": "#4dd0e1",
    "overlayBottom": "24px",
    "waveformColor": "#4dd0e1",
    "waveformHeight": "24px",
    "transcriptFontSize": "13px",
    "transcriptOpacity": 0.6,
    "highlightColor": "#ffeb3b",
    "highlightPulseDuration": 2000
  },

  "force": {
    "linkDistance": 30,
    "linkDistancePerRing": 8,
    "chargeStrength": -60,
    "radialStrength": 0.7,
    "radialRadiusPerRing": 55,
    "centerStrength": 0.05,
    "alphaDecay": 0.02
  }
}
